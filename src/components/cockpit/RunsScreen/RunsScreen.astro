---
import { Image } from 'astro:assets';
import { CURSOR, PROJECTS, PROJECT_COUNT, RUNS } from '../../../data/content';
import ArrowRightIcon from '../../icons/ArrowRightIcon/ArrowRightIcon.astro';
import './RunsScreen.scss';
---

<section id="sc-runs" class="runs" data-screen-label={RUNS.screenLabel} aria-label={RUNS.ariaLabel}>
  <div class="runs__index">
    <span class="runs__index-accent">{RUNS.inspectionMode}</span><span>//</span>
    <span id="ab-runidx">{RUNS.runLabel} 01 / {String(PROJECT_COUNT).padStart(2, '0')}</span>
  </div>
  {
    PROJECTS.map((p, i) => (
      <article data-run={i} data-screen-label={`${RUNS.runLabel} ${p.no}`} class="runs__item">
        <div class="runs__grid" data-rungrid>
          <div class="runs__copy">
            <div class="runs__meta">
              <span class="runs__no">{p.no}</span>
              <span class="runs__type">{p.type}</span>
            </div>
            <h3 class="runs__title">{p.name}</h3>
            <div class="runs__facts">
              <div>
                <div class="runs__fact-label">{RUNS.sessionBrief}</div>
                <div class="runs__fact-value">{p.brief}</div>
              </div>
              <div data-runx>
                <div class="runs__fact-label">{RUNS.trackConditions}</div>
                <div class="runs__fact-value">{p.cond}</div>
              </div>
              <div data-runx>
                <div class="runs__fact-label">{RUNS.systemSetup}</div>
                <div class="runs__fact-value">{p.setup}</div>
              </div>
              <div class="runs__footer">
                <span>{RUNS.roleLabel} // {p.role}</span><span class="runs__footer-tech">{p.tech}</span>
              </div>
            </div>
            <a href={p.link} class="runs__enter" data-run-enter data-cur={CURSOR.actions.enter} target="_blank" rel="noopener">
              {RUNS.enterLabel} <ArrowRightIcon />
            </a>
          </div>
          <div class="runs__display" data-rundisp>
            <div class="runs__display-frame">
              <div class="runs__display-header">
                <span>{RUNS.displayLabel} // {RUNS.feedLabel} {p.no}</span>
                <span class="runs__live">{RUNS.liveLabel}</span>
              </div>
              <div class="runs__display-visual">
                <Image
                  src={p.image}
                  alt={p.imageAlt}
                  width={640}
                  height={400}
                  class="runs__display-img"
                />
              </div>
              <div class="runs__display-footer">
                <span>{RUNS.resultLabel} // {p.result}</span>
              </div>
              <span class="runs__corner runs__corner--tl"></span>
              <span class="runs__corner runs__corner--tr"></span>
              <span class="runs__corner runs__corner--bl"></span>
              <span class="runs__corner runs__corner--br"></span>
            </div>
          </div>
        </div>
      </article>
    ))
  }
</section>
