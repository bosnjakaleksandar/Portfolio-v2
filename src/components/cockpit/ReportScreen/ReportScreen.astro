---
import { REPORT, REPORT_CONTENT } from '../../../data/content';
import './ReportScreen.scss';
---

<section id="sc-report" class="report" data-screen-label={REPORT_CONTENT.screenLabel} aria-label={REPORT_CONTENT.ariaLabel}>
  <div class="report__inner">
    <p class="report__eyebrow">{REPORT_CONTENT.eyebrow}</p>
    <h2 class="report__title">{REPORT_CONTENT.title}</h2>
    <div class="report__grid">
      {
        REPORT.map((r) => (
          <div class="report__stat">
            <div class="report__stat-value">{r.v}</div>
            <div class="report__stat-label">{r.k}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
