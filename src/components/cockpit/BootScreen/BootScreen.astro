---
import { BOOT, BOOT_LINES } from '../../../data/content';
import './BootScreen.scss';
---

<section id="sc-boot" class="boot" data-screen-label={BOOT.screenLabel} aria-label={BOOT.ariaLabel}>
  <div class="boot__log">
    {
      BOOT_LINES.map((b, i) => (
        <div data-boot={i} class="boot__line">
          <span>{b.k}</span><span class="boot__line-value">{b.v}</span>
        </div>
      ))
    }
    <div data-boot="99" class="boot__line boot__line--ready">
      {BOOT.ready}<span class="boot__cursor">_</span>
    </div>
  </div>
  <p id="ab-hint" class="boot__hint">{BOOT.hint}</p>
</section>
