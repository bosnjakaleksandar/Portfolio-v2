---
import { HUD } from '../../../data/content';
import './Hud.scss';
---

<div id="ab-hud" class="hud">
  <div class="hud__status">
    <svg class="hud__logo" width="19" height="19" viewBox="0 0 40 40" aria-label={HUD.logoLabel}>
      <polygon points="16,6 16,34 3,34" fill="#f2f4f6"></polygon>
      <path d="M20 6 h5 a7 7 0 0 1 0 14 h-5 z M20 20 h7 a7 7 0 0 1 0 14 h-7 z" fill="var(--acc, #4ad9e8)"></path>
    </svg>
    <span>{HUD.driverId}<span id="ab-hud-sys" class="hud__sys">{HUD.systemStatus}</span></span>
  </div>
  <div id="ab-hud-mid" class="hud__mid">
    <span>{HUD.speed} <b id="ab-spd" class="hud__value">000</b></span>
    <span>{HUD.gear} <b id="ab-gear" class="hud__value hud__value--accent">{HUD.neutralGear}</b></span>
    <span id="ab-hud-lapw">{HUD.lap} <b id="ab-lap" class="hud__value">0:00.000</b></span>
  </div>
  <div class="hud__pos">
    <span id="ab-pct">000%</span><span id="ab-hud-tp" class="hud__pos-label">{HUD.trackPosition}</span>
  </div>
</div>
<div class="hud__progress">
  <div id="ab-prog" class="hud__progress-fill"></div>
</div>
