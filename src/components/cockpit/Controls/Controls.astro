---
import speakerHigh from '../../../assets/svg/speaker-high.svg?raw';
import speakerSlash from '../../../assets/svg/speaker-slash.svg?raw';
import { CONTROLS, CURSOR } from '../../../data/content';
import './Controls.scss';

const iconOff = speakerSlash.replace('<svg ', '<svg class="controls__icon controls__icon--off" aria-hidden="true" focusable="false" ');
const iconOn = speakerHigh.replace('<svg ', '<svg class="controls__icon controls__icon--on" aria-hidden="true" focusable="false" ');
---

<div id="ab-ctl" class="controls">
  <button
    type="button"
    id="ab-btn-sound"
    class="controls__btn controls__btn--icon"
    data-cur={CURSOR.actions.toggle}
    aria-pressed="true"
    aria-label={CONTROLS.soundLabel}
  >
    <Fragment set:html={iconOff} />
    <Fragment set:html={iconOn} />
  </button>
  <audio id="ab-engine-start" preload="auto">
    <source src={CONTROLS.audio.mp3} type="audio/mpeg" />
    <source src={CONTROLS.audio.ogg} type="audio/ogg" />
  </audio>
  <button type="button" id="ab-btn-motion" class="controls__btn" data-cur={CURSOR.actions.toggle}>
    {CONTROLS.motionFull}
  </button>
</div>
