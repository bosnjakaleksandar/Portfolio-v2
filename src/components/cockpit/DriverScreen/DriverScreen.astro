---
import { Image } from 'astro:assets';
import driverPhoto from '../../../assets/driver.jpg';
import { DRIVER_ROWS } from '../../../data/content';
import './DriverScreen.scss';
---

<section id="sc-driver" class="driver" data-screen-label="Driver profile" aria-label="Driver profile">
  <div class="driver__grid" data-drvgrid>
    <div class="driver__photo" data-drvphoto>
      <div class="driver__frame">
        <div class="driver__frame-inner">
          <Image
            src={driverPhoto}
            alt="Portrait of Aleksandar Bošnjak"
            width={600}
            height={750}
            class="driver__photo-img"
          />
          <div class="driver__gradient"></div>
          <div class="driver__scanlines"></div>
          <div class="driver__id">DRIVER ID // AB-02</div>
        </div>
        <span class="driver__corner driver__corner--tl"></span>
        <span class="driver__corner driver__corner--br"></span>
      </div>
    </div>
    <div class="driver__info">
      <p class="driver__eyebrow">DRIVER TELEMETRY</p>
      <h2 class="driver__title">Built for speed, tuned for detail.</h2>
      <p class="driver__desc">
        Frontend developer focused on refined interfaces, motion-driven layouts and performant systems — from
        custom WordPress builds to modern Vue and Next.js applications.
      </p>
      <div class="driver__table">
        {
          DRIVER_ROWS.map((r, i) => (
            <div data-drow={i} class="driver__row">
              <span class="driver__row-key">{r.k}</span><span class="driver__row-value">{r.v}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
